<include>
  <!--
    Directory domain container.  mod_xml_curl handles actual user lookups
    (section=directory) so this file only needs to declare the domain so
    FreeSWITCH knows it exists.  No static users are defined here.
  -->
  <domain name="${domain}">
    <params>
      <param name="dial-string" value="{^^:sip_invite_domain=${dialed_domain}:presence_id=${dialed_user}@${dialed_domain}}${sofia_contact(*/${dialed_user}@${dialed_domain})}"/>
    </params>
    <variables>
      <variable name="user_context" value="public"/>
    </variables>
    <groups>
      <group name="default">
        <users/>
      </group>
    </groups>
  </domain>
</include>
