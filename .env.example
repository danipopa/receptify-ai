# Receptify AI — environment configuration
# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit it.

# Host IP where all services are exposed
HOST_IP=192.168.122.80

# ---- RAG service -----------------------------------------------------------
FAQ_FILE=/opt/receptify-ai/context/ai-ivr-context.txt
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=127.0.0.1:11434
RAG_CHUNK_WORDS=30
RAG_TOP_K=4
OLLAMA_TIMEOUT=20
RAG_HOST=0.0.0.0
RAG_PORT=9091

# ---- STT service -----------------------------------------------------------
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_LANGUAGE=en
STT_HOST=0.0.0.0
STT_PORT=9092

# ---- TTS service -----------------------------------------------------------
PIPER_BIN=/opt/receptify-ai/.venv/bin/piper
PIPER_MODEL=/opt/receptify-ai/piper/en_US-lessac-medium.onnx
OUTPUT_SAMPLE_RATE=8000
TTS_HOST=0.0.0.0
TTS_PORT=9093

# ---- fs-bridge -------------------------------------------------------------
FS_HOST=127.0.0.1
FS_PORT=8021
FS_PASSWORD=ClueCon
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9094

# ---- Agent -----------------------------------------------------------------
WS_HOST=0.0.0.0
WS_PORT=9090
HTTP_PORT=9095
STT_URL=http://127.0.0.1:9092
RAG_URL=http://127.0.0.1:9091
TTS_URL=http://127.0.0.1:9093
FS_BRIDGE_URL=http://127.0.0.1:9094
RECORDING_DIR=/opt/receptify-ai/recordings
RECORDING_ENABLED=false
WELCOME_MESSAGE=Thank you for calling. How can I help you today?
LOG_LEVEL=INFO
